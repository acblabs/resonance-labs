{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://resonancelab.local/schemas/phase4_dataset_manifest.schema.json",
  "title": "ResonanceLab Phase 4 Dataset Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["format", "format_version", "dataset_id", "label_schema", "records"],
  "properties": {
    "format": { "const": "resonancelab.phase4.dataset" },
    "format_version": { "const": 1 },
    "dataset_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string" },
    "description": { "type": "string" },
    "owners": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" },
    "label_schema": {
      "type": "object",
      "required": ["buckets_percent"],
      "properties": {
        "buckets_percent": {
          "type": "array",
          "items": { "type": "number", "minimum": 0, "maximum": 100 },
          "minItems": 2
        }
      }
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "label", "context"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "recorded_at": { "type": "string" },
          "audio_path": { "type": "string" },
          "analysis_path": { "type": "string" },
          "features_path": { "type": "string" },
          "exclude": { "type": "boolean" },
          "label": {
            "type": "object",
            "required": ["fill_percent"],
            "properties": {
              "fill_percent": {
                "type": "number",
                "minimum": 0,
                "maximum": 100,
                "description": "Ground-truth liquid fill percentage."
              },
              "fill_bucket": {
                "type": "string",
                "description": "Optional label matching the nearest label_schema bucket."
              },
              "fill_mass_g": {
                "type": "number",
                "description": "Liquid mass in grams, excluding empty vessel mass."
              },
              "vessel_empty_mass_g": {
                "type": "number",
                "description": "Mass of the empty vessel in grams."
              },
              "vessel_full_mass_g": {
                "type": "number",
                "description": "Mass of vessel plus liquid at the full reference in grams."
              }
            }
          },
          "context": {
            "type": "object",
            "required": ["session_id", "glass_id", "device_id", "browser_id", "room_id"],
            "properties": {
              "session_id": { "type": "string", "minLength": 1 },
              "glass_id": { "type": "string", "minLength": 1 },
              "device_id": { "type": "string", "minLength": 1 },
              "browser_id": { "type": "string", "minLength": 1 },
              "room_id": { "type": "string", "minLength": 1 },
              "operator_id": { "type": "string" },
              "volume_setting": { "type": "string" },
              "material": { "type": "string" },
              "geometry": { "type": "string" },
              "notes": { "type": "string" }
            }
          },
          "quality": {
            "type": "object",
            "properties": {
              "usable": { "type": "boolean" },
              "alignment_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "signal_to_noise_db": { "type": "number" },
              "warnings": { "type": "array", "items": { "type": "string" } }
            }
          },
          "probe": { "type": "object" }
        },
        "anyOf": [
          { "required": ["features_path"] },
          { "required": ["analysis_path"] },
          { "required": ["audio_path"] }
        ]
      }
    }
  }
}
