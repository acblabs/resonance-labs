PUBLIC_API_URL=http://localhost:8000
RESONANCELAB_ENV=local
RESONANCELAB_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Private Phase 4 capture is disabled by default. Enable only on a private
# operator deployment or for local smoke tests with PHASE4_CAPTURE_LOCAL_DIR.
PUBLIC_PHASE4_CAPTURE_ENABLED=false
PHASE4_CAPTURE_ENABLED=false
PHASE4_CAPTURE_OPERATOR_TOKEN=
PHASE4_CAPTURE_GCS_BUCKET=
PHASE4_CAPTURE_INBOX_PREFIX=phase4/inbox
PHASE4_CAPTURE_STORE_RAW_AUDIO=true
PHASE4_CAPTURE_LOCAL_DIR=

# Optional lab-assistant explanations. The API accepts structured explain
# requests even when disabled, but only calls Gemini when this is true.
RESONANCELAB_LLM_ENABLED=false
RESONANCELAB_LLM_PROVIDER=vertex_gemini
RESONANCELAB_LLM_MODEL=gemini-3.1-pro-preview
RESONANCELAB_LLM_LOCATION=global
RESONANCELAB_LLM_THINKING_LEVEL=HIGH
RESONANCELAB_LLM_MAX_OUTPUT_TOKENS=900
GOOGLE_GENAI_USE_ENTERPRISE=true

# Keep real GCP project IDs, service account names, and trigger substitutions in
# Google Cloud Build trigger settings or ignored local files such as
# .env.gcp.local. Do not commit project-specific deployment values here.
